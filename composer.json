{
    "name": "secretwebmaster/wncms-core",
    "description": "Wncms core package",
    "keywords": [
        "wncms",
        "laravel",
        "cms",
        "secretwebmaster"
    ],
    "type": "library",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.1",
        "laravel/socialite": "^5.26",
        "secretwebmaster/laravel-localization": "2.4.0.x-dev",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-permission": "^6.21",
        "secretwebmaster/wncms-tags": "1.8.x-dev",
        "secretwebmaster/wncms-translatable": "1.4.x-dev",
        "secretwebmaster/laravel-optionable": "2.1.x-dev",
        "fakerphp/faker": "^1.23"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^12.5",
        "orchestra/testbench": "^11.0",
        "barryvdh/laravel-debugbar": "^4.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../laravel-localization",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../laravel-optionable",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../wncms-tags",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../wncms-translatable",
            "options": {
                "symlink": true
            }
        }
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Wncms\\": "src/",
            "Wncms\\Database\\": "database/",
            "Wncms\\Database\\Factories\\": "database/factories/",
            "Wncms\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wncms\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wncms\\Tags\\TagsServiceProvider",
                "Wncms\\Providers\\WncmsServiceProvider",
                "Wncms\\Providers\\EventServiceProvider",
                "Wncms\\Providers\\HelpersProvider",
                "Wncms\\Providers\\MailServiceProvider",
                "Wncms\\Providers\\ObserverServiceProvider",
                "Wncms\\Providers\\PluginServiceProvider",
                "Wncms\\Providers\\RouteServiceProvider",
                "Wncms\\Providers\\SettingsServiceProvider",
                "Wncms\\Providers\\ThemeServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "6.3.x-dev"
        }
    },
    "authors": [
        {
            "name": "secretwebmaster",
            "email": "earnbyshare2016@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/secretwebmaster/wncms-core/issues",
        "source": "https://github.com/secretwebmaster/wncms-core"
    },
    "homepage": "https://github.com/secretwebmaster/wncms-core",
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:dox": "vendor/bin/phpunit --testdox --colors=always",
        "test:unit": "vendor/bin/phpunit --testsuite Unit --testdox --colors=always",
        "test:feature": "vendor/bin/phpunit --testsuite Feature --testdox --colors=always",
        "test:install": "vendor/bin/phpunit tests/Unit/WncmsInstallationStateTest.php --testdox --colors=always",
        "test:post": "vendor/bin/phpunit --filter Post --testdox --colors=always",
        "test:prepare-db": "tests/bin/prepare-test-db.sh"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
